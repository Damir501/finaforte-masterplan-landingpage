# Brevo proxy credentials — kopieer dit bestand naar `.env` in dezelfde dir
# en vul je echte Brevo API key in. De .env zit niet in Git (zie .gitignore).
#
# Hoe te activeren op productie (masterplan.finaforte.nl):
#   1. Login cPanel File Manager
#   2. Ga naar public_html/api/
#   3. New File → naam: .env
#   4. Plak: BREVO_API_KEY=jouw-echte-key
#   5. Save
#
# Brevo API key vind je via: https://app.brevo.com → Profile (rechtsboven) →
#   SMTP & API → API Keys → Generate a new API key (full access).
#
# De .htaccess in deze dir blokkeert publieke toegang tot .env.

BREVO_API_KEY=xkeysib-jouw-echte-key-hier

# Calendly webhook signing secret — voor api/calendly-webhook.php (F5-bevestigingsmail).
# Genereer in Calendly via: Account → Integrations → Webhooks → Create webhook →
# kopieer de "Signing key" hier.
CALENDLY_WEBHOOK_SECRET=plak-hier-je-calendly-signing-key

# Calendly tracking webhook signing secret — voor api/calendly-track-webhook.php.
# Meet-only: registreert call_booked in het dashboard en update Brevo-attributen,
# maar verstuurt GEEN F5-mail. Gebruik een aparte Calendly webhook-subscription
# zodat Zapier de bestaande F5-bevestiging kan blijven doen.
CALENDLY_TRACKING_WEBHOOK_SECRET=plak-hier-je-aparte-tracking-signing-key

# Calendly Personal Access Token — voor api/dashboard.php (cockpit-metrics M2/M3).
# Genereer via: https://calendly.com/integrations/api_webhooks → Personal Access Tokens →
# "Get a token now" → naam "Dashboard V0" → kopieer (eenmalig getoond).
# Scope: lezen van scheduled_events. Hier NIET een webhook-secret invullen.
CALENDLY_API_TOKEN=eyJ...plak-hier-je-calendly-PAT

# Dashboard email-gate whitelist — comma-separated emails die zonder gate door mogen
# naar /dashboard/. Andere bezoekers krijgen reguliere email-gate workflow.
DASHBOARD_AUTH_EMAILS=info@finaforte.nl
